{
  "name": "pigeon-aeo",
  "version": "0.1.0",
  "description": "Install Pigeon in your codebase. Logs into your Pigeon account, picks a workspace, and applies the AEO/GEO fixes (schema, FAQ pages, atomic facts) it generated — framework-aware, on a review branch.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./next": "./src/next.ts"
  },
  "bin": {
    "pigeon": "./bin/cli.mjs"
  },
  "files": ["src", "bin", "README.md"],
  "keywords": [
    "aeo",
    "geo",
    "seo",
    "ai-search",
    "llms.txt",
    "schema.org",
    "chatgpt",
    "perplexity"
  ],
  "license": "MIT",
  "homepage": "https://github.com/npmiaman/AutoAEO/tree/main/packages/sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/npmiaman/AutoAEO.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/npmiaman/AutoAEO/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true }
  }
}
