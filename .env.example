# AutoAEO environment variables. Copy to .env.local and fill in values.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (local SQLite by default; libsql URL for Turso)
DATABASE_URL=file:./local.db
# DATABASE_AUTH_TOKEN=  (only set this for hosted libsql / Turso)

# Encryption key for Shopify access tokens at rest.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# better-auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Shopify Partner App credentials (https://partners.shopify.com/)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Google Generative AI (Gemini chat + embeddings).
# Get a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# LangSmith tracing (optional but recommended for the LangGraph agent).
# Get a key at https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=autoaeo
