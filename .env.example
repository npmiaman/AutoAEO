# AutoAEO environment variables. Copy to .env.local and fill in values.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (local SQLite by default)
DATABASE_URL=file:./local.db

# Encryption key for Shopify access tokens at rest.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# better-auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Shopify Partner App credentials (https://partners.shopify.com/)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Anthropic API key for the agent brain (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
